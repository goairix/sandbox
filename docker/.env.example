# Sandbox Docker Compose Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Storage backend: local, s3, cos, oss, obs, minio
STORAGE_PROVIDER=local

# Object storage settings (for s3/cos/oss/obs/minio)
STORAGE_BUCKET=
STORAGE_ENDPOINT=
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_SUB_PATH=
STORAGE_USE_SSL=false

# Local storage path (for local provider)
STORAGE_LOCAL_PATH=/data/storage

# API authentication key
SECURITY_API_KEY=***REDACTED_API_KEY***
