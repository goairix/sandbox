# Sandbox Docker Compose Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Storage backend: local, s3, cos, oss, obs, minio
STORAGE_PROVIDER=local

# Object storage settings (for s3/cos/oss/obs/minio)
STORAGE_BUCKET=
STORAGE_ENDPOINT=
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_SUB_PATH=
STORAGE_USE_SSL=false

# Local storage path (for local provider)
STORAGE_LOCAL_PATH=/data/storage

# Redis state store
REDIS_PASSWORD=
REDIS_DB=0

# API authentication key
SECURITY_API_KEY=change-me

# Sandbox timeout (seconds)
SANDBOX_TIMEOUT_SECONDS=3600

# Container pool sizing
POOL_MIN_SIZE=3
POOL_MAX_SIZE=20
